# Template variabili d'ambiente per llama-server ottimizzato
# Copia questo file in .env e personalizza i valori

# Percorso ai modelli GGUF (relativo o assoluto)
MODEL_PATH=./models

# Livello di log (debug, info, warn, error)
LOG_LEVEL=info

# Porta per metriche Prometheus (se abilitate)
METRICS_PORT=8091

# Timeout per operazioni di rete (secondi)
NETWORK_TIMEOUT=30

# Abilita profiling avanzato (true/false)
ENABLE_PROFILING=false

# Directory per log e file temporanei
LOG_DIR=./logs
TEMP_DIR=./tmp

# Numero massimo di richieste in coda
MAX_QUEUE=100

# Numero massimo di richieste parallele
MAX_PARALLEL=4

# Abilita health check endpoint (true/false)
ENABLE_HEALTH_CHECK=true

# Intervallo health check (secondi)
HEALTH_CHECK_INTERVAL=30

# Abilita CORS per API (true/false)
ENABLE_CORS=false

# Origini consentite per CORS (se abilitato)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Abilita autenticazione di base (true/false)
ENABLE_BASIC_AUTH=false

# Credenziali per autenticazione di base (se abilitato)
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=changeme

# Abilita logging dettagliato delle richieste (true/false)
ENABLE_REQUEST_LOGGING=false

# Abilita compressione risposte HTTP (true/false)
ENABLE_HTTP_COMPRESSION=true

# Dimensione massima richiesta HTTP (MB)
MAX_REQUEST_SIZE=10

# Timeout generazione token (secondi)
GENERATION_TIMEOUT=300

# Abilita streaming di risposta (true/false)
ENABLE_STREAMING=true

# Dimensione buffer per streaming (KB)
STREAM_BUFFER_SIZE=64

# Abilita caching prompt (true/false)
ENABLE_PROMPT_CACHING=false

# TTL cache prompt (secondi)
PROMPT_CACHE_TTL=3600

# Abilita monitoring GPU avanzato (true/false)
ENABLE_GPU_MONITORING=true

# Intervallo monitoring GPU (secondi)
GPU_MONITORING_INTERVAL=5

# Abilita alert su utilizzo VRAM (true/false)
ENABLE_VRAM_ALERT=true

# Soglia utilizzo VRAM per alert (%)
VRAM_ALERT_THRESHOLD=90

# Abilita alert su temperatura GPU (true/false)
ENABLE_TEMP_ALERT=true

# Soglia temperatura GPU per alert (°C)
TEMP_ALERT_THRESHOLD=80

# Abilita alert su utilizzo CPU (true/false)
ENABLE_CPU_ALERT=true

# Soglia utilizzo CPU per alert (%)
CPU_ALERT_THRESHOLD=95

# Abilita alert su memoria di sistema (true/false)
ENABLE_SYSTEM_MEMORY_ALERT=true

# Soglia utilizzo memoria di sistema per alert (%)
SYSTEM_MEMORY_ALERT_THRESHOLD=90

# Abilita logging strutturato JSON (true/false)
ENABLE_JSON_LOGGING=false

# Abilita reporting errori dettagliato (true/false)
ENABLE_DETAILED_ERROR_REPORTING=true

# Abilita validazione input rigorosa (true/false)
ENABLE_STRICT_INPUT_VALIDATION=true

# Abilita fallback a CPU in caso di errore GPU (true/false)
ENABLE_GPU_FALLBACK=false

# Abilita ottimizzazioni memoria avanzate (true/false)
ENABLE_ADVANCED_MEMORY_OPTIMIZATIONS=true

# Abilita pre-allocation buffer KV cache (true/false)
ENABLE_KV_CACHE_PREALLOC=true

# Dimensione pre-allocation KV cache (MB)
KV_CACHE_PREALLOC_SIZE=512

# Abilita quantizzazione dinamica attivazioni (true/false)
ENABLE_DYNAMIC_ACTIVATION_QUANTIZATION=false

# Abilita ottimizzazioni memoria condivisa (true/false)
ENABLE_SHARED_MEMORY_OPTIMIZATIONS=true

# Abilita pinning memoria pagine grandi (true/false)
ENABLE_HUGE_PAGE_PINNING=false